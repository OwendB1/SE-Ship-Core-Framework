<?xml version="1.0" ?>
<Definitions xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
	<CubeBlocks>
		<Definition xsi:type="MyObjectBuilder_UpgradeModuleDefinition">
			<Id>
				<TypeId>UpgradeModule</TypeId>
				<SubtypeId>SG_GridCore_Module_OverDrive</SubtypeId>
			</Id>
			<DisplayName>GridCore UpgradeModule: Overdrive</DisplayName>
			<Description>This Module is built for one thing, SPEED!</Description>
			<Icon>Textures\SmallGridUpgrade.png</Icon>
			<CubeSize>Small</CubeSize>
			<BlockTopology>TriangleMesh</BlockTopology>
			<Size x="1" y="1" z="1"/>
			<ModelOffset x="0" y="0" z="0"/>
			<Model>Models\SG_GridCore_Upgrade.mwm</Model>
			<Components>
				<Component Subtype="SteelPlate" Count="10"/>
			</Components>
			<CriticalComponent Subtype="SteelPlate" Index="0"/>
			<BuildProgressModels>
				<Model BuildPercentUpperBound="0.50" File="Models\SG_GridCore_Upgrade_BS1.mwm"/>
				<Model BuildPercentUpperBound="1.00" File="Models\SG_GridCore_Upgrade_BS2.mwm"/>
			</BuildProgressModels>
			<MirroringX>Z</MirroringX>
			<MirroringZ>X</MirroringZ>
			<MountPoints>
				<MountPoint Side="Front" StartX="0.00" StartY="0.00" EndX="0.09" EndY="1.00"/>
				<MountPoint Side="Front" StartX="0.83" StartY="0.00" EndX="1.00" EndY="1.00"/>
				<MountPoint Side="Back" StartX="0.00" StartY="0.80" EndX="1.00" EndY="1.00"/>
				<MountPoint Side="Back" StartX="0.00" StartY="0.00" EndX="1.00" EndY="0.20"/>
				<MountPoint Side="Back" StartX="0.00" StartY="0.00" EndX="0.09" EndY="1.00"/>
				<MountPoint Side="Left" StartX="0.00" StartY="0.00" EndX="1.00" EndY="1.00"/>
				<MountPoint Side="Right" StartX="0.00" StartY="0.00" EndX="1.00" EndY="1.00"/>
				<MountPoint Side="Top" StartX="0.00" StartY="0.00" EndX="1.00" EndY="1.00"/>
				<MountPoint Side="Bottom" StartX="0.00" StartY="0.00" EndX="1.00" EndY="1.00"/>
			</MountPoints>
			<BlockPairName>GridCore_Module_OverDrive</BlockPairName>
			<MirroringY>Z</MirroringY>
			<MirroringZ>Y</MirroringZ>
            <EdgeType>Light</EdgeType>
            <Upgrades>
                <MyUpgradeModuleInfo>
                    <UpgradeType>ThrusterForce</UpgradeType>
                    <Modifier>1.2</Modifier>
					<ModifierType>Multiplicative</ModifierType>
                </MyUpgradeModuleInfo>
                <MyUpgradeModuleInfo>
                    <UpgradeType>ThrusterEfficiency</UpgradeType>
                    <Modifier>0.8</Modifier>
					<ModifierType>Multiplicative</ModifierType>
                </MyUpgradeModuleInfo>
                <MyUpgradeModuleInfo>
                    <UpgradeType>MaxSpeed</UpgradeType>
                    <Modifier>0.05</Modifier>
					<ModifierType>Additive</ModifierType>
                </MyUpgradeModuleInfo>
                <MyUpgradeModuleInfo>
                    <UpgradeType>MaxBoost</UpgradeType>
                    <Modifier>0.05</Modifier>
					<ModifierType>Additive</ModifierType>
                </MyUpgradeModuleInfo>
                <MyUpgradeModuleInfo>
                    <UpgradeType>BoostDuration</UpgradeType>
                    <Modifier>1.2</Modifier>
					<ModifierType>Multiplicative</ModifierType>
                </MyUpgradeModuleInfo>
                <MyUpgradeModuleInfo>
                    <UpgradeType>BoostDuration</UpgradeType>
                    <Modifier>1.2</Modifier>
					<ModifierType>Multiplicative</ModifierType>
                </MyUpgradeModuleInfo>
            </Upgrades>
            <PrimarySound>BlockModuleProductivity</PrimarySound>
            <DamageEffectName>Damage_Electrical_Damaged</DamageEffectName>
            <DamagedSound>ParticleElectrical</DamagedSound>
            <EmissiveColorPreset>Default</EmissiveColorPreset>
            <DestroyEffect>BlockDestroyedExplosion_Large</DestroyEffect>
            <DestroySound>WepSmallWarheadExpl</DestroySound>
            <PCU>1</PCU>
            <IsAirTight>false</IsAirTight>
		</Definition>
	</CubeBlocks>
</Definitions>