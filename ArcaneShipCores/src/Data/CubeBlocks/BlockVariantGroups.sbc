        </BlockVariantGroup>

        <BlockVariantGroup>
            <Id Type="MyObjectBuilder_BlockVariantGroup" Subtype="Utility Cores" />
            <Icon>Textures\LargeGridCore.png</Icon>
            <DisplayName>Warship Cores</DisplayName>
            <Description>Warship Cores, the necessary componets for the ultimate fleet.</Description>
            <Blocks>
                <Block Type="MyObjectBuilder_Beacon" Subtype="Utility_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Extractor_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Courier_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Harvester_Core" />               
