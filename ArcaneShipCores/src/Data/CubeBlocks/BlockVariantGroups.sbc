            <Description>Station Cores, the heart of you bases.</Description>
            <Blocks>
                <Block Type="MyObjectBuilder_Beacon" Subtype="Outpost_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Stronghold_Core" />
