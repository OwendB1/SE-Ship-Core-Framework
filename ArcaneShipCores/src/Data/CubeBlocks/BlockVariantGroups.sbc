            <Description>Warship Cores, the necessary componets for the ultimate fleet.</Description>
            <Blocks>
                <Block Type="MyObjectBuilder_Beacon" Subtype="Frigate_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Cruiser_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Destroyer_Core" />
                <Block Type="MyObjectBuilder_Beacon" Subtype="Battleship_Core" />
                
                <Block Type="MyObjectBuilder_Beacon" Subtype="Interceptor_Core" />
